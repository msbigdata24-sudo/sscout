SCRAPINGBEE_API_KEY=
SCRAPINGFISH_API_KEY=
# Рекомендуем ZenRows (прокси РФ): https://app.zenrows.com/register
ZENROWS_API_KEY=

# Порт: на Render задаётся автоматически (PORT). Локально — 8765.
# SIGNAL_SCOUT_PORT=8765
# SERP_PAGES=4
# SERP_MAX_RESULTS_PER_QUERY=100
XMLRIVER_USER=
XMLRIVER_KEY=

# Резерв: прямой Яндекс XML API (если XMLRiver недоступен)
YANDEX_XML_USER=
YANDEX_XML_KEY=

SIGNAL_SCOUT_PORT=8765
# На Render с persistent disk: /opt/render/project/src/data/signal_scout.db
# SIGNAL_SCOUT_DB_PATH=
# Пароль админа — видит все прогоны в истории (Render → Environment)
ADMIN_PASSWORD=
CRAWL_CONCURRENCY=8
# Фильтр «живой сайт»: таймаут одного сайта и общий лимит секунд на шаг
# FILTER_ALIVE_TIMEOUT=6
# FILTER_ALIVE_BUDGET_SEC=120
# FILTER_ALIVE_CONCURRENCY=16
HTTP_TIMEOUT=15
SITE_TIMEOUT=30
FETCH_RETRIES=3
